{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["POM/*"],
      "@interfaces/*": ["interfaces/*"],
      "@helpers/*": ["helpers/*"],
      "@utils/*": ["API/utils/*"]
    }
  },
  "include": ["POM", "tests", "API"]
}
